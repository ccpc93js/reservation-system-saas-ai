# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL — required for cron self-calls in production (set to your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Cron secret — Vercel automatically sends this as `Authorization: Bearer $CRON_SECRET`
# for scheduled cron jobs. Set this in your Vercel project env vars.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret

# Anthropic (OCR / AI features)
ANTHROPIC_API_KEY=your-anthropic-key

# Resend (email)
RESEND_API_KEY=your-resend-key
