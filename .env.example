# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep SECRET, server only

# ─── Site URL ────────────────────────────────────────────────────────────────
# Required for cron self-calls, QR codes, Stripe redirect URLs, and the
# server-to-server email dispatch call — set to your production deployment URL.
# Falls back to VERCEL_URL (auto-populated by Vercel) then localhost if unset.
# Also add this + /auth/callback to Supabase Dashboard > Auth > URL Configuration > Redirect URLs
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ─── Cron ────────────────────────────────────────────────────────────────────
# Vercel automatically sends this as `Authorization: Bearer $CRON_SECRET`
# for scheduled cron jobs (see vercel.json). Set this in your Vercel project env vars.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret

# ─── Anthropic (OCR / AI features) ───────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@yourdomain.com

# ─── Channex (channel manager — API OTA connections) ─────────────────────────
# Master API key from Channex dashboard → user settings → API keys. SECRET,
# server only, never commit. Base URL selects sandbox vs production.
CHANNEX_API_KEY=your-channex-key
CHANNEX_BASE_URL=https://staging.channex.io/api/v1   # prod: https://app.channex.io/api/v1
# Shared secret appended to the webhook callback URL (?secret=...) so the
# inbound booking webhook can reject forged calls. Generate: openssl rand -hex 32
CHANNEX_WEBHOOK_SECRET=your-webhook-secret

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_SCALE_MONTHLY=price_...
