# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep SECRET, server only

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HostelHub

# ─── Passport / ID Scanning ──────────────────────────────────────────────────
# Option A: Google Document AI (recommended for accuracy)
# Get from: https://console.cloud.google.com → Document AI → ID Document Parser
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us             # or eu
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json   # path to GCP service account key

# Option B: AWS Textract (faster to set up)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ─── Stripe (billing — add in Week 7) ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email (Resend — add in Week 6 for online check-in links) ─────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
